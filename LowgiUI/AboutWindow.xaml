<Window x:Class="LowgiUI.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About Lowgi"
        Width="390"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        WindowStartupLocation="CenterScreen"
        BorderThickness="0"
        Background="{DynamicResource TrayMenuBackgroundBrush}"
        Foreground="{DynamicResource TrayMenuTextBrush}">
    <Window.Resources>
        <Style x:Key="DarkCloseButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource TrayMenuTextBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource TrayMenuHoverBrush}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{DynamicResource TrayMenuPressedBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DarkActionButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource DarkCloseButtonStyle}">
            <Setter Property="Background" Value="{DynamicResource TrayMenuButtonBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource TrayMenuBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource TrayMenuHoverBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource TrayMenuLinkBrush}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{DynamicResource TrayMenuPressedBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border x:Name="AboutWindowBorder"
            Background="{DynamicResource TrayMenuBackgroundBrush}"
            BorderBrush="{DynamicResource TrayMenuBorderBrush}"
            BorderThickness="1"
            CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="34" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid x:Name="TitleBar"
                  Grid.Row="0"
                  Background="{DynamicResource TrayMenuTitleBrush}"
                  MouseLeftButtonDown="TitleBarMouseLeftButtonDown">
                <TextBlock Text="About Lowgi"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0"
                           FontSize="12"
                           Foreground="{DynamicResource TrayMenuTextBrush}" />
                <Button Content="X"
                        HorizontalAlignment="Right"
                        Width="34"
                        Style="{StaticResource DarkCloseButtonStyle}"
                        Click="CloseButtonClick" />
            </Grid>

            <StackPanel Grid.Row="1"
                        Margin="18">
                <TextBlock Text="Lowgi by RygTech"
                           FontSize="17"
                           FontWeight="SemiBold"
                           Margin="0,0,0,7" />

                <TextBlock Text="Low battery indicator for Logitech devices."
                           FontSize="13"
                           Foreground="{DynamicResource TrayMenuTextBrush}"
                           Margin="0,0,0,14" />

                <TextBlock Text="{Binding VersionLabel}"
                           FontSize="13"
                           Foreground="{DynamicResource TrayMenuTextBrush}"
                           Margin="0,0,0,14" />

                <TextBlock FontSize="13"
                           Foreground="{DynamicResource TrayMenuTextBrush}"
                           Margin="0,0,0,8">
                    <Run Text="URL: " />
                    <Hyperlink NavigateUri="https://rygtech.org"
                               RequestNavigate="HyperlinkRequestNavigate"
                               Foreground="{DynamicResource TrayMenuLinkBrush}">
                        <Run Text="Rygtech.org" />
                    </Hyperlink>
                    <Run Text=" | Contact: " />
                    <Hyperlink NavigateUri="mailto:hello@rygtech.org"
                               RequestNavigate="HyperlinkRequestNavigate"
                               Foreground="{DynamicResource TrayMenuLinkBrush}">
                        <Run Text="hello@rygtech.org" />
                    </Hyperlink>
                </TextBlock>

                <TextBlock FontSize="13"
                           Foreground="{DynamicResource TrayMenuTextBrush}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,18">
                    <Run Text="For any bugs you may encounter, please report them on " />
                    <Hyperlink NavigateUri="https://github.com/BagerRyg/Lowgi"
                               RequestNavigate="HyperlinkRequestNavigate"
                               Foreground="{DynamicResource TrayMenuLinkBrush}">
                        <Run Text="Github" />
                    </Hyperlink>
                </TextBlock>

                <Button Content="Close"
                        HorizontalAlignment="Right"
                        MinWidth="72"
                        Padding="12,5"
                        Style="{StaticResource DarkActionButtonStyle}"
                        Click="CloseButtonClick" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
