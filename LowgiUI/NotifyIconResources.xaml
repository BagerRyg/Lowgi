<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:LowgiUI"
                    xmlns:tb="http://www.hardcodet.net/taskbar">
    <SolidColorBrush x:Key="TrayMenuBackgroundBrush" Color="#0D1117" />
    <SolidColorBrush x:Key="TrayMenuHoverBrush" Color="#2D333B" />
    <SolidColorBrush x:Key="TrayMenuPressedBrush" Color="#3A424D" />
    <SolidColorBrush x:Key="TrayMenuDangerHoverBrush" Color="#7F1D1D" />
    <SolidColorBrush x:Key="TrayMenuDangerPressedBrush" Color="#991B1B" />
    <SolidColorBrush x:Key="TrayMenuBorderBrush" Color="#30363D" />
    <SolidColorBrush x:Key="TrayMenuTextBrush" Color="#F0F6FC" />
    <SolidColorBrush x:Key="TrayMenuDisabledTextBrush" Color="#8B949E" />
    <SolidColorBrush x:Key="TrayMenuTitleBrush" Color="#161B22" />
    <SolidColorBrush x:Key="TrayMenuButtonBrush" Color="#21262D" />
    <SolidColorBrush x:Key="TrayMenuLinkBrush" Color="#58A6FF" />
    <SolidColorBrush x:Key="TrayMenuScrollThumbBrush" Color="#7D8590" />

    <ItemsPanelTemplate x:Key="DarkTrayItemsPanelTemplate">
        <StackPanel Background="{DynamicResource TrayMenuBackgroundBrush}" IsItemsHost="True" />
    </ItemsPanelTemplate>

    <ControlTemplate TargetType="{x:Type MenuItem}" x:Key="DarkTrayMenuItemTemplate">
        <Border x:Name="Root"
                Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                CornerRadius="4"
                Margin="0">
            <Grid MinHeight="{TemplateBinding MinHeight}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="34" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="26" />
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="CheckMark"
                           Text="&#x2713;"
                           Grid.Column="0"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{TemplateBinding Foreground}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Visibility="Collapsed" />

                <ContentPresenter Grid.Column="1"
                                  ContentSource="Header"
                                  RecognizesAccessKey="True"
                                  VerticalAlignment="Center"
                                  Margin="0,0,12,0" />

                <TextBlock x:Name="SubmenuArrow"
                           Text="{Binding Path=(local:TraySubmenuController.SubmenuArrowText), RelativeSource={RelativeSource TemplatedParent}}"
                           Grid.Column="{Binding Path=(local:TraySubmenuController.SubmenuArrowColumn), RelativeSource={RelativeSource TemplatedParent}}"
                           FontSize="20"
                           Foreground="{TemplateBinding Foreground}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Visibility="Collapsed" />
            </Grid>
        </Border>
        <ControlTemplate.Triggers>
            <Trigger Property="IsHighlighted" Value="True">
                <Setter TargetName="Root" Property="Background" Value="{DynamicResource TrayMenuHoverBrush}" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Root" Property="Background" Value="{DynamicResource TrayMenuPressedBrush}" />
            </Trigger>
            <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
            </Trigger>
            <Trigger Property="Role" Value="TopLevelHeader">
                <Setter TargetName="SubmenuArrow" Property="Visibility" Value="Visible" />
            </Trigger>
            <Trigger Property="Role" Value="SubmenuHeader">
                <Setter TargetName="SubmenuArrow" Property="Visibility" Value="Visible" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Foreground" Value="{DynamicResource TrayMenuDisabledTextBrush}" />
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <ControlTemplate TargetType="{x:Type MenuItem}" x:Key="DarkTrayDangerMenuItemTemplate">
        <Border x:Name="Root"
                Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                CornerRadius="4"
                Margin="0">
            <Grid MinHeight="{TemplateBinding MinHeight}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="34" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="26" />
                </Grid.ColumnDefinitions>

                <ContentPresenter Grid.Column="1"
                                  ContentSource="Header"
                                  RecognizesAccessKey="True"
                                  VerticalAlignment="Center"
                                  Margin="0,0,12,0" />
            </Grid>
        </Border>
        <ControlTemplate.Triggers>
            <Trigger Property="IsHighlighted" Value="True">
                <Setter TargetName="Root" Property="Background" Value="{DynamicResource TrayMenuDangerHoverBrush}" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Root" Property="Background" Value="{DynamicResource TrayMenuDangerPressedBrush}" />
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <ControlTemplate TargetType="{x:Type MenuItem}" x:Key="DarkTrayFooterMenuItemTemplate">
        <Border x:Name="Root"
                Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                CornerRadius="4"
                Margin="0">
            <ContentPresenter ContentSource="Header"
                              RecognizesAccessKey="True"
                              VerticalAlignment="Center" />
        </Border>
    </ControlTemplate>

    <ControlTemplate TargetType="{x:Type MenuItem}" x:Key="DarkTraySubmenuTemplate">
        <Border x:Name="Root"
                Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                CornerRadius="4"
                Margin="0">
            <Grid MinHeight="{TemplateBinding MinHeight}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="34" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="26" />
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="CheckMark"
                           Text="&#x2713;"
                           Grid.Column="0"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{TemplateBinding Foreground}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Visibility="Collapsed" />

                <ContentPresenter Grid.Column="1"
                                  ContentSource="Header"
                                  RecognizesAccessKey="True"
                                  VerticalAlignment="Center"
                                  Margin="0,0,12,0" />

                <TextBlock x:Name="SubmenuArrow"
                           Text="{Binding Path=(local:TraySubmenuController.SubmenuArrowText), RelativeSource={RelativeSource TemplatedParent}}"
                           Grid.Column="{Binding Path=(local:TraySubmenuController.SubmenuArrowColumn), RelativeSource={RelativeSource TemplatedParent}}"
                           FontSize="20"
                           Foreground="{TemplateBinding Foreground}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Visibility="Collapsed" />

                <Popup x:Name="PART_Popup"
                       Grid.ColumnSpan="3"
                       AllowsTransparency="True"
                       Focusable="False"
                       IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                       Placement="Custom"
                       PlacementTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                       PopupAnimation="None">
                    <Grid>
                        <Border x:Name="PopupBorder"
                                Background="{DynamicResource TrayMenuBackgroundBrush}"
                                BorderBrush="{DynamicResource TrayMenuBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="4"
                                Margin="{Binding Path=(local:TraySubmenuController.SubmenuBorderMargin), RelativeSource={RelativeSource TemplatedParent}}">
                            <ScrollViewer CanContentScroll="True"
                                          Style="{DynamicResource DarkTrayScrollViewerStyle}">
                                <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle" />
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Popup>
            </Grid>
        </Border>
        <ControlTemplate.Triggers>
            <Trigger Property="IsHighlighted" Value="True">
                <Setter TargetName="Root" Property="Background" Value="{DynamicResource TrayMenuHoverBrush}" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Root" Property="Background" Value="{DynamicResource TrayMenuPressedBrush}" />
            </Trigger>
            <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
            </Trigger>
            <Trigger Property="Role" Value="TopLevelHeader">
                <Setter TargetName="SubmenuArrow" Property="Visibility" Value="Visible" />
            </Trigger>
            <Trigger Property="Role" Value="SubmenuHeader">
                <Setter TargetName="SubmenuArrow" Property="Visibility" Value="Visible" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Foreground" Value="{DynamicResource TrayMenuDisabledTextBrush}" />
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <Style TargetType="{x:Type Thumb}" x:Key="DarkTrayScrollThumbStyle">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Thumb}">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="5" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type ScrollBar}" x:Key="DarkTrayScrollBarStyle">
        <Setter Property="Width" Value="10" />
        <Setter Property="Background" Value="{DynamicResource TrayMenuBackgroundBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ScrollBar}">
                    <Grid Background="{TemplateBinding Background}">
                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" />
                            </Track.DecreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb Background="{DynamicResource TrayMenuScrollThumbBrush}"
                                       BorderBrush="{DynamicResource TrayMenuBorderBrush}"
                                       BorderThickness="0"
                                       Style="{StaticResource DarkTrayScrollThumbStyle}" />
                            </Track.Thumb>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" />
                            </Track.IncreaseRepeatButton>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type ScrollViewer}" x:Key="DarkTrayScrollViewerStyle">
        <Setter Property="Background" Value="{DynamicResource TrayMenuBackgroundBrush}" />
        <Setter Property="VerticalScrollBarVisibility" Value="Disabled" />
        <Setter Property="HorizontalScrollBarVisibility" Value="Disabled" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ScrollViewer}">
                    <Grid Background="{TemplateBinding Background}">
                        <ScrollContentPresenter CanContentScroll="{TemplateBinding CanContentScroll}" />
                        <ScrollBar x:Name="PART_VerticalScrollBar"
                                   HorizontalAlignment="Right"
                                   Maximum="{TemplateBinding ScrollableHeight}"
                                   ViewportSize="{TemplateBinding ViewportHeight}"
                                   Value="{TemplateBinding VerticalOffset}"
                                   Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                                   Style="{StaticResource DarkTrayScrollBarStyle}" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type Separator}" x:Key="DarkTraySeparatorStyle">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Separator}">
                    <Border Height="1" Margin="10,6" Background="{DynamicResource TrayMenuBorderBrush}" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <ControlTemplate TargetType="{x:Type MenuItem}" x:Key="DarkTrayMenuSeparatorItemTemplate">
        <Border Height="1" Margin="10,6" Background="{DynamicResource TrayMenuBorderBrush}" />
    </ControlTemplate>

    <Style TargetType="{x:Type ContextMenu}" x:Key="DarkTrayContextMenuStyle">
        <Setter Property="Background" Value="{DynamicResource TrayMenuBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource TrayMenuBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="4" />
        <Setter Property="ItemsPanel" Value="{StaticResource DarkTrayItemsPanelTemplate}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ContextMenu}">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle"
                                        SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type MenuItem}" x:Key="DarkTrayMenuItemStyle">
        <Setter Property="Foreground" Value="{DynamicResource TrayMenuTextBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="MinHeight" Value="34" />
        <Setter Property="MinWidth" Value="150" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="ItemsPanel" Value="{StaticResource DarkTrayItemsPanelTemplate}" />
        <Setter Property="Template" Value="{StaticResource DarkTrayMenuItemTemplate}" />
        <Style.Triggers>
            <Trigger Property="Role" Value="TopLevelHeader">
                <Setter Property="Template" Value="{StaticResource DarkTraySubmenuTemplate}" />
            </Trigger>
            <Trigger Property="Role" Value="SubmenuHeader">
                <Setter Property="Template" Value="{StaticResource DarkTraySubmenuTemplate}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="{x:Type MenuItem}" BasedOn="{StaticResource DarkTrayMenuItemStyle}" />

    <Style TargetType="{x:Type MenuItem}" x:Key="DarkTrayMainMenuItemStyle" BasedOn="{StaticResource DarkTrayMenuItemStyle}">
        <Setter Property="MinWidth" Value="260" />
    </Style>

    <Style TargetType="{x:Type MenuItem}" x:Key="DarkTrayQuitMenuItemStyle" BasedOn="{StaticResource DarkTrayMainMenuItemStyle}">
        <Setter Property="Template" Value="{StaticResource DarkTrayDangerMenuItemTemplate}" />
    </Style>

    <Style TargetType="{x:Type MenuItem}" x:Key="DarkTrayFooterMenuItemStyle" BasedOn="{StaticResource DarkTrayMainMenuItemStyle}">
        <Setter Property="Template" Value="{StaticResource DarkTrayFooterMenuItemTemplate}" />
    </Style>

    <Style TargetType="{x:Type Button}" x:Key="TrayThemeButtonStyle">
        <Setter Property="Width" Value="26" />
        <Setter Property="Height" Value="24" />
        <Setter Property="Margin" Value="2,0,0,0" />
        <Setter Property="Background" Value="{DynamicResource TrayMenuButtonBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TrayMenuTextBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource TrayMenuBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4">
                        <ContentPresenter Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource TrayMenuHoverBrush}" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{DynamicResource TrayMenuPressedBrush}" />
            </Trigger>
            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="True">
                <Setter Property="Background" Value="{DynamicResource TrayMenuPressedBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource TrayMenuLinkBrush}" />
                <Setter Property="BorderThickness" Value="2" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="{x:Type Button}" x:Key="TrayQuitButtonStyle" BasedOn="{StaticResource TrayThemeButtonStyle}">
        <Setter Property="Width" Value="Auto" />
        <Setter Property="Height" Value="28" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="Padding" Value="34,0,0,0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource TrayMenuDangerHoverBrush}" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{DynamicResource TrayMenuDangerPressedBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

	<ContextMenu x:Shared="True"
                 x:Key="SysTrayMenu"
                 Background="{DynamicResource TrayMenuBackgroundBrush}"
                 BorderBrush="{DynamicResource TrayMenuBorderBrush}"
                 BorderThickness="1"
                 Padding="4"
                 Placement="Top"
                 VerticalOffset="-6"
                 local:TraySubmenuController.Enable="True"
                 ItemsPanel="{StaticResource DarkTrayItemsPanelTemplate}"
                 ItemContainerStyle="{StaticResource DarkTrayMainMenuItemStyle}"
                 Style="{StaticResource DarkTrayContextMenuStyle}">
        <MenuItem Header="Devices" ItemsSource="{Binding DeviceMenuEntries}">
                <MenuItem.ItemContainerStyle>
                    <Style TargetType="MenuItem" BasedOn="{StaticResource DarkTrayMenuItemStyle}">
                        <Setter Property="Header" Value="{Binding Header}" />
                        <Setter Property="IsCheckable" Value="{Binding IsDevice}"/>
                        <Setter Property="IsChecked" Value="{Binding Device.IsChecked, Mode=TwoWay}"/>
                        <Setter Property="IsEnabled" Value="{Binding IsEnabled}"/>
                        <Setter Property="StaysOpenOnClick" Value="True"/>
                        <Setter Property="Command">
                            <Setter.Value>
                                <Binding Path="DataContext.DeviceMenuEntryClickedCommand" RelativeSource="{RelativeSource AncestorType=ContextMenu}"/>
                            </Setter.Value>
                        </Setter>
                        <Setter Property="CommandParameter" Value="{Binding}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsDevice}" Value="True">
                                <Setter Property="Header" Value="{Binding Device.DeviceName}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsSeparator}" Value="True">
                                <Setter Property="Template" Value="{StaticResource DarkTrayMenuSeparatorItemTemplate}" />
                                <Setter Property="MinHeight" Value="1" />
                                <Setter Property="MinWidth" Value="0" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </MenuItem.ItemContainerStyle>
        </MenuItem>
        <MenuItem Header="Display Numeric Icon" IsCheckable="True" IsChecked="{Binding NumericDisplay}" StaysOpenOnClick="True" />
        <MenuItem Header="Warn about low battery" IsCheckable="True" IsChecked="{Binding LowBatteryWarning}" StaysOpenOnClick="True" />
        <MenuItem Header="Low battery threshold">
            <MenuItem Header="2%" MinWidth="120" IsCheckable="True" IsChecked="{Binding LowBatteryWarningThreshold2}" StaysOpenOnClick="True" />
            <MenuItem Header="5%" MinWidth="120" IsCheckable="True" IsChecked="{Binding LowBatteryWarningThreshold5}" StaysOpenOnClick="True" />
            <MenuItem Header="10%" MinWidth="120" IsCheckable="True" IsChecked="{Binding LowBatteryWarningThreshold10}" StaysOpenOnClick="True" />
            <MenuItem Header="15%" MinWidth="120" IsCheckable="True" IsChecked="{Binding LowBatteryWarningThreshold15}" StaysOpenOnClick="True" />
            <MenuItem Header="20%" MinWidth="120" IsCheckable="True" IsChecked="{Binding LowBatteryWarningThreshold20}" StaysOpenOnClick="True" />
        </MenuItem>
        <MenuItem Header="Mouse LED">
            <MenuItem Header="Dynamic" MinWidth="120" IsCheckable="True" IsChecked="{Binding LedModeDynamic}" StaysOpenOnClick="True" />
            <MenuItem Header="Bright White" MinWidth="120" IsCheckable="True" IsChecked="{Binding LedModeWhite}" StaysOpenOnClick="True" />
            <MenuItem Header="Dim White" MinWidth="120" IsCheckable="True" IsChecked="{Binding LedModeGrey}" StaysOpenOnClick="True" />
            <MenuItem Header="Low Battery" MinWidth="120" IsCheckable="True" IsChecked="{Binding LedModeLowBattery}" StaysOpenOnClick="True" />
            <MenuItem Header="Always Off" MinWidth="120" IsCheckable="True" IsChecked="{Binding LedModeOff}" StaysOpenOnClick="True" />
        </MenuItem>
        <MenuItem Header="Advanced">
            <MenuItem Header="Update interval">
                <MenuItem Header="1 min" MinWidth="120" IsCheckable="True" IsChecked="{Binding BatteryPollingInterval1}" StaysOpenOnClick="True" />
                <MenuItem Header="3 min" MinWidth="120" IsCheckable="True" IsChecked="{Binding BatteryPollingInterval3}" StaysOpenOnClick="True" />
                <MenuItem Header="5 min" MinWidth="120" IsCheckable="True" IsChecked="{Binding BatteryPollingInterval5}" StaysOpenOnClick="True" />
                <MenuItem Header="10 min" MinWidth="120" IsCheckable="True" IsChecked="{Binding BatteryPollingInterval10}" StaysOpenOnClick="True" />
            </MenuItem>
            <MenuItem Header="Autostart with Windows" MinWidth="180" IsCheckable="True" IsChecked="{Binding AutoStart}" StaysOpenOnClick="True" />
            <MenuItem Header="Enable debug logging" MinWidth="180" IsCheckable="True" IsChecked="{Binding EnableLogging}" StaysOpenOnClick="True" />
            <MenuItem Header="About Lowgi" MinWidth="180" Command="{Binding ShowAboutCommand}" />
        </MenuItem>
        <Separator Style="{StaticResource DarkTraySeparatorStyle}" />
        <MenuItem Style="{StaticResource DarkTrayFooterMenuItemStyle}" StaysOpenOnClick="True">
            <MenuItem.Header>
                <Grid Width="252" Height="28">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Button Content="{Binding QuitHeader}"
                            Command="{Binding DataContext.QuitApplicationCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                            Style="{StaticResource TrayQuitButtonStyle}" />
                    <StackPanel Orientation="Horizontal"
                                Grid.Column="1"
                                HorizontalAlignment="Right">
                        <Button Command="{Binding DataContext.SetDarkThemeCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                Tag="{Binding DataContext.DarkTheme, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                ToolTip="Dark mode"
                                Style="{StaticResource TrayThemeButtonStyle}">
                            <Viewbox Width="14" Height="14">
                                <Path Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      Data="M15.5,2.5 C12,3.5 9.5,6.8 9.5,10.5 C9.5,15.2 13.3,19 18,19 C18.8,19 19.6,18.9 20.3,18.7 C18.8,20.7 16.4,22 13.7,22 C8.4,22 4,17.6 4,12.3 C4,7.6 7.4,3.6 11.9,2.7 C13.1,2.4 14.3,2.3 15.5,2.5 Z" />
                            </Viewbox>
                        </Button>
                        <Button Command="{Binding DataContext.SetLightThemeCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                Tag="{Binding DataContext.LightTheme, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                ToolTip="Light mode"
                                Style="{StaticResource TrayThemeButtonStyle}">
                            <Viewbox Width="15" Height="15">
                                <Grid Width="24" Height="24">
                                    <Ellipse Width="8" Height="8"
                                             Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center" />
                                    <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                          StrokeThickness="2"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          Data="M12,1 L12,4 M12,20 L12,23 M4.2,4.2 L6.3,6.3 M17.7,17.7 L19.8,19.8 M1,12 L4,12 M20,12 L23,12 M4.2,19.8 L6.3,17.7 M17.7,6.3 L19.8,4.2" />
                                </Grid>
                            </Viewbox>
                        </Button>
                    </StackPanel>
                </Grid>
            </MenuItem.Header>
        </MenuItem>
    </ContextMenu>

    <local:ThemeBrushConverter x:Key="ThemeBrushConverter" />

    <tb:TaskbarIcon x:Key="NotifyIcon"
                    ContextMenu="{StaticResource SysTrayMenu}">
    </tb:TaskbarIcon>
</ResourceDictionary>
